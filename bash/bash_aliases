# Internal helper for bsub requests
# 参数: queue mem gpu_spec model_req threads slots
#   slots: LSF job slot 数量 (GPU 命令 = GPU 数量, CPU 命令 = 线程数)
_bsub_req() {
    local q=$1 mem=$2 gpu_spec=$3 model_req=$4 threads=$5 slots=$6

    local model_msg=""
    if [ -n "$model_req" ]; then model_msg=" (Model: $model_req)"; fi

    local thread_count=${threads:-4}
    # GPU 命令: -n = GPU 数量; CPU 命令: -n = 线程数
    local slot_count=${slots:-$thread_count}

    echo "Requesting ${q} node: ${mem}GB RAM, ${thread_count} Threads, ${slot_count} Slots, ${gpu_spec:-No GPU}${model_msg}..."

    bsub -q "$q" \
         -n "${slot_count}" \
         ${gpu_spec:+-gpu "$gpu_spec"} \
         -R "rusage[mem=${mem}GB]" \
         -R "affinity[thread*${thread_count}]" \
         -R "hname!=ibdgxa01" \
         ${model_req:+-R "select[$model_req]"} \
         -Is /bin/bash
}

# 用法: cpuRequire [内存GB] [线程数]
# 例子: cpuRequire 64 8  -> 64GB, 8线程, 8 slots (CPU = slots 跟线程走)
cpuRequire()  { _bsub_req interactive ${1:-32} "" "" ${2:-4}; }

# 用法: gpuRequire [内存GB] [线程数]
# 例子: gpuRequire 80 8  -> 80GB, 8线程, 1 GPU, 1 slot
gpuRequire()  { _bsub_req interactive-gpu ${1:-64} "num=1:j_exclusive=yes" "" ${2:-4} 1; }

# 用法: gpuRequire2 [内存GB] [线程数]
# 例子: gpuRequire2 128 16 -> 128GB, 16线程, 2 GPU, 2 slots
gpuRequire2() { _bsub_req interactive-gpu ${1:-64} "num=2:j_exclusive=yes" "" ${2:-4} 2; }

# 用法: gpuA100 [内存大小] [线程数]
# 例子: gpuA100 80 2  -> 80GB, 2线程, 1 GPU, 1 slot
gpuA100() {
    _bsub_req interactive-gpu ${1:-80} "num=1:j_exclusive=yes" "gpumodel=='A100'" ${2:-4} 1
}

# 用法: gpuL40S [内存大小] [线程数]
gpuL40S() {
    _bsub_req interactive-gpu ${1:-64} "num=1:j_exclusive=yes" "gpumodel=='L40S'" ${2:-4} 1
}

