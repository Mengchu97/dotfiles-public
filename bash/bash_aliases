upy() {
    if [[ "$1" == *.py ]]; then
        local target="$1"
        [[ "$target" == ./* ]] && target="${target:2}"
        local module="${target%.py}"
        module="${module//\//.}"
        echo "Auto-detected script, running as module: $module"
        if ! uv run python -m "$module" "${@:2}"; then
            echo "Module run failed, falling back to direct script execution..."
            uv run python "$@"
        fi
    else
        uv run python "$@"
    fi
}
