# Push dotfiles updates
dotpush() {
    (
        cd ~/.dotfiles || return
        git add .
        if git commit -m "${1:-update dotfiles}"; then
            echo "🚀 Pushing changes..."
            git push origin main
        else
            echo "✨ No changes to push."
        fi
    )
}

# Pull dotfiles updates and reload
dotpull() {
    (
        cd ~/.dotfiles || return
        git pull origin main
    )
    [ -f ~/.bashrc ] && source ~/.bashrc
}

# Ensure git include directive is present (self-healing if install.sh wasn't run)
if [ -f ~/.gitconfig ] && [ -f ~/.dotfiles/git/gitconfig ]; then
    if ! grep -q '# >>> dotfiles >>>' ~/.gitconfig 2>/dev/null; then
        {
            echo ""
            echo "# >>> dotfiles >>>"
            echo "[include]"
            echo "    path = ~/.dotfiles/git/gitconfig"
            echo "# <<< dotfiles <<<"
        } >> ~/.gitconfig
    fi
fi

# --- OpenCode Plugin Toggle (omo vs oms) ---
# Tracks active mode via ~/.config/opencode/.oc-mode
_oc_active_mode() {
    local marker="$HOME/.config/opencode/.oc-mode"
    if [ -f "$marker" ]; then cat "$marker"; else echo "oms"; fi
}

_oc_plugin_set() {
    local mode="$1"
    local f

    # 1. Update opencode.json (Main plugins)
    # Non-destructively swap oh-my-opencode-slim and oh-my-openagent@latest
    for f in \
        "$HOME/.config/opencode/opencode.json" \
        "$HOME/.dotfiles/opencode/opencode.json"
    do
        [ -f "$f" ] || continue
        if [ "$mode" = "omo" ]; then
            # Replace slim with agent@latest
            sed -i 's/oh-my-opencode-slim/oh-my-openagent@latest/g' "$f"
        else
            # Replace agent (with optional version) with slim
            sed -i 's/oh-my-openagent\(@[^"]*\)\?/oh-my-opencode-slim/g' "$f"
        fi
    done

    # 2. Update tui.json (TUI specific plugins)
    for f in \
        "$HOME/.config/opencode/tui.json" \
        "$HOME/.dotfiles/opencode/tui.json"
    do
        [ -f "$f" ] || continue
        if [ "$mode" = "oms" ]; then
            # Ensure oh-my-opencode-slim is present
            if grep -q "oh-my-openagent" "$f"; then
                sed -i 's/oh-my-openagent\(@[^"]*\)\?/oh-my-opencode-slim/g' "$f"
            elif ! grep -q "oh-my-opencode-slim" "$f"; then
                if grep -q '^[[:space:]]*{[[:space:]]*}[[:space:]]*$' "$f"; then
                    printf '{\n  "plugin": [\n    "oh-my-opencode-slim"\n  ]\n}\n' > "$f"
                else
                    # Add to existing plugin list
                    sed -i '/"plugin": \[/a \    "oh-my-opencode-slim",' "$f"
                fi
            fi
        else
            # For omo mode, remove slim from TUI while preserving other plugins
            # Pure bash (awk) logic to maintain JSON validity (comma handling)
            awk '
                !/oh-my-opencode-slim|oh-my-openagent/ { lines[++n] = $0 }
                END {
                    for (i = 1; i <= n; i++) {
                        # Remove trailing comma if next line is a closing bracket
                        if (lines[i] ~ /,[[:space:]]*$/ && lines[i+1] ~ /^[[:space:]]*\]/) {
                            sub(/,[[:space:]]*$/, "", lines[i])
                        }
                        print lines[i]
                    }
                }
            ' "$f" > "${f}.tmp" && mv "${f}.tmp" "$f"
        fi
    done

    echo "$mode" > "$HOME/.config/opencode/.oc-mode"
    local label="oh-my-openagent"
    [ "$mode" = "oms" ] && label="oh-my-opencode-slim"
    echo "✅ Enabled ${label} (restart opencode to apply)"
}

ocenable-omo() { _oc_plugin_set "omo"; }
ocenable-oms() { _oc_plugin_set "oms"; }

# --- OpenCode Profile Switcher ---
# Tracks active profile via ~/.config/opencode/.omo-profile
_omo_active_profile() {
    local marker="$HOME/.config/opencode/.omo-profile"
    if [ -f "$marker" ]; then cat "$marker"; else echo "unknown"; fi
}

_omo_switch() {
    local profile="$1"
    local src="$HOME/.dotfiles/opencode/oh-my-openagent-${profile}.json"
    local tgt="$HOME/.config/opencode/oh-my-openagent.json"
    local dotfile="$HOME/.dotfiles/opencode/oh-my-openagent.json"
    if [ ! -f "$src" ]; then
        echo "❌ Profile not found: $src"
        return 1
    fi
    cp "$src" "$tgt"
    cp "$src" "$dotfile"
    echo "$profile" > "$HOME/.config/opencode/.omo-profile"
    echo "✅ Switched to ${profile} profile (restart opencode to apply)"
}

omo-glm()     { _omo_switch "glm"; }
omo-gpt()     { _omo_switch "gpt"; }
omo-manual()  { _omo_switch "manual"; }
omo-status()  {
    local profile=$(_omo_active_profile)
    echo "Active oh-my-openagent profile: ${profile}"
}

