wtclone ()
{
    local wtree_input="${1:?Usage: wtclone <worktree_dir> [branch]}";
    local branch="$2";
    local wtree repo rel_path src dst dst_dir;

    wtree="$(python3 -c "import os,sys; print(os.path.abspath(sys.argv[1]))" "$wtree_input")";

    repo="$(git rev-parse --show-toplevel 2>/dev/null)" || {
        echo "Error: not inside a git repo";
        return 1;
    };

    if [ ! -d "$wtree" ]; then
        git -C "$repo" worktree add "$wtree" ${branch:+"$branch"} || return 1;
    else
        echo "Note: $wtree already exists, skipping worktree creation";
    fi;

    echo "Symlinking gitignored items: $repo → $wtree";

    # Collect linked paths for .gitignore injection
    local linked_paths=();

    while IFS= read -r rel_path; do
        rel_path="${rel_path%/}"

        case "$rel_path" in
            __pycache__/*|*.pyc|*.pyo|.pytest_cache/*|.mypy_cache/*)
                continue
                ;;
        esac

        src="$repo/$rel_path"
        dst="$wtree/$rel_path"
        dst_dir="$(dirname "$dst")"

        [ -e "$src" ] || continue
        [ -d "$dst_dir" ] || mkdir -p "$dst_dir"

        if [ ! -e "$dst" ] && [ ! -L "$dst" ]; then
            ln -s "$src" "$dst" \
                && echo "  Linked:  $rel_path" \
                || echo "  Warning: failed $rel_path"
            # Record for .gitignore (strip trailing slashes for matching)
            linked_paths+=("$rel_path")
        else
            echo "  Skip:    $rel_path"
        fi

    done < <(git -C "$repo" ls-files --others --ignored --exclude-standard --directory);

    # Ensure symlinks are ignored in the worktree's .gitignore
    # (symlinks to directories are treated as files by git, so patterns
    #  like ".venv/" with trailing slash won't match them)
    if [ ${#linked_paths[@]} -gt 0 ]; then
        local wt_gitignore="$wtree/.gitignore"
        local needs_newline=""
        # $(...) strips trailing newlines, so when file ends with \n the
        # result is empty → != "" is false → no extra newline needed.
        if [ -f "$wt_gitignore" ] && [ -s "$wt_gitignore" ] && [ "$(tail -c1 "$wt_gitignore")" != "" ]; then
            needs_newline=$'\n'
        fi
        {
            echo "${needs_newline}# --- wtclone symlinks (auto-generated) ---"
            for p in "${linked_paths[@]}"; do
                echo "$p"
            done
        } >> "$wt_gitignore"
        echo "  Updated .gitignore with ${#linked_paths[@]} symlink(s)"
    fi

    echo "Done."
}

# Gemini CLI
gresume() {
    if [ -z "$1" ]; then
        echo "Usage: gresume <session-id>" >&2
        return 1
    fi

    local project_id=$(basename "$PWD" | tr '[:upper:]' '[:lower:]' | tr '_' '-')
    local root_file="$HOME/.gemini/tmp/$project_id/.project_root"

    mkdir -p "$(dirname "$root_file")"
    echo -n "$PWD" > "$root_file"
    gemini --resume "$@"
}
alias glatest='gemini --resume latest'
