}


# Python Virtual Env Activation
activate() {
    local venv_name="."
    local venv_path=""

    if [ -n "$1" ]; then
        venv_name="$1"
    fi

    # Search for the virtual environment
    if [[ "$venv_name" == "." || "$venv_name" == "venv" || "$venv_name" == ".venv" ]]; then
        if [ -d "./.venv" ]; then venv_path="./.venv";
        elif [ -d "./venv" ]; then venv_path="./venv"; fi
    else
        if [ -d "$HOME/envs/$venv_name" ]; then venv_path="$HOME/envs/$venv_name";
        elif [ -d "$HOME/.virtualenvs/$venv_name" ]; then venv_path="$HOME/.virtualenvs/$venv_name";
        elif [ -d "./$venv_name" ]; then venv_path="./$venv_name"; fi
    fi

    # Detect activation script (compatibility: Linux/macOS uses 'bin', Windows uses 'Scripts')
    local act_script=""
    if [ -n "$venv_path" ]; then
        if [ -f "$venv_path/bin/activate" ]; then act_script="$venv_path/bin/activate"
        elif [ -f "$venv_path/Scripts/activate" ]; then act_script="$venv_path/Scripts/activate"
        fi
    fi

    # Activate
    if [ -n "$act_script" ]; then
        printf "Activating virtual environment '\e[36m%s\e[0m'...\n" "$(basename "$venv_path")"
        source "$act_script"

        # Extra project env (Mitsuba example)
        if [[ "$venv_path" == "./.venv" || "$venv_path" == "./venv" ]]; then
            local extra_env="$(pwd)/external/mitsuba/build/setpath.sh"
            if [ -f "$extra_env" ]; then
                echo "Loading Mitsuba environment from $extra_env"
                . "$extra_env"
            fi
        fi
    else
        printf "\e[31mError:\e[0m Could not find virtual environment '%s'.\n" "$venv_name"
        return 1
    fi
}


